// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model movies {
  id           String @id @map("_id") @db.ObjectId
  movie_banner String
  movie_rating String
  movie_name   String
  movie_year   Int
  movie_genre  String
}